# Registry the `@dbx-tools/*` packages are pulled from.
#
# This demo is a real downstream CONSUMER of the published packages, not a
# member of the main repo's workspace - so it installs them as normal versioned
# dependencies. Point this at wherever the packages live:
#
#   - Local development against a local registry (e.g. verdaccio):
#       @dbx-tools:registry=http://localhost:4873/
#   - Public npm once the packages are released (delete this scope line, or):
#       @dbx-tools:registry=https://registry.npmjs.org/
#
# Only the `@dbx-tools` scope is redirected; everything else resolves from the
# default registry.
@dbx-tools:registry=http://localhost:4873/
